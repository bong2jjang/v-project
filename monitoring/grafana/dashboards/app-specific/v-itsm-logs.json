      "title": "필터된 로그 스트림",
      "description": "템플릿 변수 $level·$search 로 실시간 필터. 기본은 error/warning 만 표시. 전체 레벨 보기는 $level 에 `info|debug` 추가.",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{container=~\"v-project-itsm-.*\"} | json | level=~\"$level\" |~ \"$search\" | line_format \"[{{.level}}] {{.event}} {{.message}}\"",
          "refId": "A"
        }
      ]
    }
