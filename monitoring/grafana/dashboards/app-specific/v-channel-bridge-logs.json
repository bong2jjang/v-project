{
  "title": "VMS Channel Bridge - 로그 조회",
  "uid": "vms-channel-bridge-logs",
  "description": "자주 사용하는 Loki 로그 쿼리 모음",
  "tags": ["vms", "logs", "loki"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "컨테이너",
        "type": "query",
        "datasource": { "type": "loki", "uid": "Loki" },
        "query": "label_values(container)",
        "includeAll": true,
        "allValue": "vms-channel-bridge.*",
        "multi": false,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "level",
        "label": "로그 레벨",
        "type": "custom",
        "query": "all,error,warning,info,debug",
        "includeAll": false,
        "current": { "text": "all", "value": "all" },
        "options": [
          { "text": "전체", "value": "all" },
          { "text": "error", "value": "error" },
          { "text": "warning", "value": "warning" },
          { "text": "info", "value": "info" },
          { "text": "debug", "value": "debug" }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "전체 로그",
      "description": "vms-channel-bridge 컨테이너 전체 로그",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{container=~\"vms-channel-bridge.*\"}",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 2,
      "type": "logs",
      "title": "에러 / 경고 로그",
      "description": "error 또는 warning 레벨 로그만 필터",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{container=~\"vms-channel-bridge.*\"} | json | level =~ \"error|warning\"",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 3,
      "type": "logs",
      "title": "API 요청 로그",
      "description": "HTTP GET/POST/PUT/DELETE/PATCH 요청",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{container=\"vms-channel-bridge-backend\"} |~ \"(GET|POST|PUT|DELETE|PATCH) /api\"",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "WebSocket 연결 로그",
      "description": "WebSocket 연결/해제/에러 이벤트",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
