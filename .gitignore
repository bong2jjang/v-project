# 환경 변수 파일 (보안 정보 포함)
.env

# node_modules (Docker symlink 포함)
**/node_modules

# 로그 파일
*.log

# 임시 파일
*.tmp
*.tmp.*
*.swp
*~

# 백업 파일
*.backup
.backups/

# OS 관련
.DS_Store
Thumbs.db

# IDE 설정
.idea/
*.iml

# VSCode - 개인 설정만 제외, 프로젝트 공유 설정은 포함
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/

# Frontend lib 디렉토리는 포함 (Python lib과 구분)
!frontend/src/lib/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
venv/
ENV/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.eslintcache
.pnpm-store/

# Build outputs
dist/
dist-ssr/
*.local

# Playwright
/frontend/test-results/
/frontend/playwright-report/
/frontend/playwright/.cache/
