# VMS Matterbridge Backend 환경 변수 샘플

# ======================
# 데이터베이스 설정
# ======================
DATABASE_URL=postgresql://vmsuser:vmspassword@postgres:5432/vms_matterbridge

# ======================
# Redis 설정
# ======================
REDIS_URL=redis://:redispassword@redis:6379/0

# ======================
# 보안 설정
# ======================
SECRET_KEY=vms-matterbridge-secret-key-change-in-production-12345

# ======================
# 환경 설정
# ======================
ENVIRONMENT=development

# ======================
# SMTP 이메일 설정 (비밀번호 재설정)
# ======================

# 개발 환경 (MailHog 사용)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=mailhog
SMTP_PASSWORD=mailhog

# 프로덕션 환경 (Gmail 예시)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-gmail-app-password

# 프로덕션 환경 (SendGrid 예시)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# 프로덕션 환경 (AWS SES 예시)
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USERNAME=your-ses-smtp-username
# SMTP_PASSWORD=your-ses-smtp-password

# 발신자 정보
SMTP_FROM_EMAIL=noreply@vms-matterbridge.com
SMTP_FROM_NAME=VMS Matterbridge

# 프론트엔드 URL (비밀번호 재설정 링크에 사용)
FRONTEND_URL=http://localhost:5173

# ======================
# Gmail 앱 비밀번호 생성 방법
# ======================
# 1. Google 계정 설정 (https://myaccount.google.com) 접속
# 2. 보안 탭 선택
# 3. 2단계 인증 활성화 (필수)
# 4. 앱 비밀번호 생성:
#    - 앱 선택: 메일
#    - 기기 선택: 기타 (사용자 지정 이름)
#    - 이름 입력: "VMS Matterbridge"
# 5. 생성된 16자리 비밀번호를 SMTP_PASSWORD에 입력
#
# ⚠️ 주의: .env 파일은 절대 Git에 커밋하지 마세요!

# ======================
# MailHog (개발용 메일 서버)
# ======================
# Web UI: http://localhost:8025
# SMTP Port: 1025
#
# 테스트 방법:
# 1. docker-compose.yml에 MailHog 서비스가 설정되어 있어야 함
# 2. 비밀번호 재설정 요청 후 http://localhost:8025 접속
# 3. 발송된 이메일 확인
