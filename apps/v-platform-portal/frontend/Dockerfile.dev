# pnpm Workspace Development Environment
FROM node:18-alpine

RUN corepack enable && corepack prepare pnpm@latest --activate
RUN apk add --no-cache wget

WORKDIR /workspace

# Workspace config
COPY .npmrc pnpm-workspace.yaml package.json ./
COPY platform/frontend/v-platform-core/package.json ./platform/frontend/v-platform-core/
COPY apps/v-platform-portal/frontend/package.json ./apps/v-platform-portal/frontend/
COPY pnpm-lock.yaml* ./

# Install dependencies (workspace-aware)
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --filter v-platform-portal-frontend... --no-frozen-lockfile --prefer-offline

WORKDIR /workspace/apps/v-platform-portal/frontend

EXPOSE 5173
CMD ["pnpm", "run", "dev", "--", "--host", "0.0.0.0"]
