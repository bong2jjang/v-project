# ==========================================================
# v-platform-template 앱 전용 환경 변수
# ==========================================================
# 공용 변수(DATABASE_URL, REDIS_URL, SECRET_KEY, SMTP_*, TEAMS_TENANT_ID/APP_ID/APP_PASSWORD 등)는
# 루트 `.env`에 정의되어 있습니다. 현재 template 앱 고유 설정은 없습니다.
# 새 앱을 이 템플릿에서 복제할 때 여기에 앱 전용 변수를 추가하세요.
#
# 사용법:
#   cp apps/v-platform-template/.env.example apps/v-platform-template/.env
#
# docker-compose.yml 의 template-backend 서비스 `env_file:` 로 주입됩니다.
# ==========================================================

# SMTP From Name (앱별 override, 미지정 시 compose 기본값 사용)
# SMTP_FROM_NAME=v-platform-template

# 예시: 앱 고유 API 키
# MY_APP_API_KEY=
