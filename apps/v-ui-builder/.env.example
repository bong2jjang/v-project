# ==========================================================
# v-ui-builder 앱 전용 환경 변수
# ==========================================================
# 공용 변수(DATABASE_URL, REDIS_URL, SECRET_KEY, SMTP_*, TEAMS_TENANT_ID/APP_ID/APP_PASSWORD 등)는
# 루트 `.env`에 정의되어 있습니다. 여기에는 ui-builder 앱만 사용하는 값을 둡니다.
#
# 사용법:
#   cp apps/v-ui-builder/.env.example apps/v-ui-builder/.env
#   # 실제 값 채우기
#
# docker-compose.yml 의 ui-builder-backend 서비스 `env_file:` 로 주입됩니다.
# ==========================================================

# LLM Provider 설정 (openai | anthropic | local)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# SMTP From Name (앱별 override, 미지정 시 compose 기본값 사용)
# SMTP_FROM_NAME=v-ui-builder
