# ==========================================================
# v-channel-bridge 앱 전용 환경 변수
# ==========================================================
# 공용 변수(DATABASE_URL, REDIS_URL, SECRET_KEY, SMTP_*, TEAMS_TENANT_ID/APP_ID/APP_PASSWORD 등)는
# 루트 `.env`에 정의되어 있습니다. 여기에는 bridge 앱만 사용하는 값을 둡니다.
#
# 사용법:
#   cp apps/v-channel-bridge/.env.example apps/v-channel-bridge/.env
#   # 실제 값 채우기
#
# docker-compose.yml 의 backend 서비스 `env_file:` 로 주입됩니다.
# ==========================================================

# Slack Provider (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# Teams Provider (Graph API) - bridge 전용 팀 ID
# 주의: TEAMS_TENANT_ID / TEAMS_APP_ID / TEAMS_APP_PASSWORD 는 SSO와 공유되므로 루트 .env 에 정의
TEAMS_TEAM_ID=your-teams-team-id

# Microsoft OAuth Delegated Auth (선택)
MS_OAUTH_REDIRECT_URI=

# Graph API Change Notifications 웹훅 공개 URL (선택)
TEAMS_NOTIFICATION_URL=

# SMTP From Name (앱별 override, 미지정 시 compose 기본값 사용)
# SMTP_FROM_NAME=v-channel-bridge
