# ==========================================================
# v-itsm 앱 전용 환경 변수
# ==========================================================
# 공용 변수(DATABASE_URL, REDIS_URL, SECRET_KEY, SMTP_*, TEAMS_TENANT_ID/APP_ID/APP_PASSWORD 등)는
# 루트 `.env`에 정의되어 있습니다. 아래는 v-itsm 고유 설정입니다.
#
# 사용법:
#   cp apps/v-itsm/.env.example apps/v-itsm/.env
#
# docker-compose.yml 의 itsm-backend 서비스 `env_file:` 로 주입됩니다.
# ==========================================================

# SMTP From Name (앱별 override, 미지정 시 compose 기본값 사용)
# SMTP_FROM_NAME=v-itsm

# ── SLA 정책 기본값 ──────────────────────────────────────────
# 영업시간 정책(기본 24x7). 값: 24x7 | business_hours
# SLA_BUSINESS_HOURS_MODE=24x7
# 티켓 미지정 상태로 남겨둘 수 있는 최대 분. 초과 시 경고 이벤트 발생.
# SLA_UNASSIGNED_WARNING_MINUTES=30

# ── AI/LLM 연동 (선택) ─────────────────────────────────────
# v-ui-builder 의 BaseLLMProvider 를 재사용해 요약/추천/답변초안 생성.
# 비워 두면 AI 기능이 비활성화 된 상태로 기동됩니다.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ── 알림 채널 기본값 ────────────────────────────────────────
# v-channel-bridge 로 위임. 채널 자격 증명은 bridge 쪽 .env 를 따릅니다.
# ITSM_DEFAULT_NOTIFY_CHANNELS=slack,teams,email
