# Slack 설정
# Slack App의 Bot User OAuth Token
# 형식: xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Slack 채널 ID 또는 이름
# 채널 ID는 Slack에서 채널 우클릭 > "링크 복사"에서 확인 가능
# 예: general, C0123456789
SLACK_CHANNEL_ID=general

# Microsoft Teams 설정
# Azure AD Tenant ID
# Azure Portal > Azure Active Directory > 개요에서 확인
TEAMS_TENANT_ID=your-tenant-id-here

# Teams Bot App ID (Application/Client ID)
# Azure Portal > App Registrations에서 생성한 앱의 Application ID
TEAMS_APP_ID=your-app-id-here

# Teams Bot App Password (Client Secret)
# Azure Portal > App Registrations > Certificates & secrets에서 생성
TEAMS_APP_PASSWORD=your-app-password-here

# Teams 채널 ID
# Teams에서 채널 우클릭 > "팀에 대한 링크 가져오기"에서 추출
# 형식: 19:xxxxxxxxxxxxxxxxxxxxxxxxxxxx@thread.tacv2
TEAMS_CHANNEL_ID=19:your-channel-id@thread.tacv2

# Email (MailHog)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM_EMAIL=noreply@v-project.local
SMTP_FROM_NAME=v-project

PUBLIC_HOST=192.168.1.216
FRONTEND_URL=http://localhost:5173
BACKEND_URL=https://w9hz7vqx-8000.jpe1.devtunnels.ms
MS_OAUTH_REDIRECT_URI=https://w9hz7vqx-8000.jpe1.devtunnels.ms/api/auth/microsoft/callback